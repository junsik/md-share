{
  "name": "md-share",
  "version": "1.3.3",
  "description": "Self-hostable markdown rendering and sharing service — upload markdown, get a shareable rendered link",
  "license": "MIT",
  "author": "junsik",
  "repository": {
    "type": "git",
    "url": "https://github.com/junsik/md-share.git"
  },
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "lint": "eslint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ui-guide:capture": "pnpm build && node tools/ui-guide/capture.mjs",
    "ui-guide:verify": "pnpm build && node tools/ui-guide/capture.mjs --verify"
  },
  "dependencies": {
    "github-slugger": "^2.0.0",
    "highlight.js": "^11.11.1",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.12.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "playwright": "1.61.1",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
